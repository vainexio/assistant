modules = ["nodejs-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Run Bot"
mode = "sequential"
author = 46456541

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm start"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Bot (Production)"

[[workflows.workflow]]
name = "Run Bot (Production)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server.js"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 80
